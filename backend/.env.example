# OpenRouter
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# Sui
# Mysten public JSON-RPC (fullnode.testnet.sui.io) is being shut down (2026-07); use a
# working public JSON-RPC node, or a keyed provider (Shinami/BlockVision/QuickNode).
SUI_RPC_URL=https://sui-testnet-rpc.publicnode.com
SUI_NETWORK=testnet

# DeepBook Predict (Testnet)
DEEPBOOK_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
DEEPBOOK_PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
DEEPBOOK_REGISTRY_ID=0x43af14fed5480c20ff77e2263d5f794c35b9fab7e2212903127062f4fe2a6e64
DEEPBOOK_PUBLIC_SERVER_URL=https://predict-server.testnet.mystenlabs.com
DEEPBOOK_PREDICT_SERVER=https://predict-server.testnet.mystenlabs.com

# DUSDC
DUSDC_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC
DUSDC_CURRENCY_ID=0xf3000dff421833d4bb8ed58fac146d691a3aaba2785aa1989af65a7089ca3e9c
DUSDC_DECIMALS=6

# Walrus (HTTP publisher to store blobs, aggregator gateway to read — no CLI needed)
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_GATEWAY_URL=https://aggregator.walrus-testnet.walrus.space/v1
# Proof blob lifetime in epochs (testnet epoch ≈ 1 day). 53 = protocol max (~53 days)
# so proofs don't expire mid-event.
WALRUS_EPOCHS=53

# ESPN API
ESPN_API_BASE_URL=https://your-espn-service.example.com
ESPN_API_KEY=

# Database
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_NAME=sheka
DB_POSTGRES_USER=root
DB_POSTGRES_PASSWORD=
DB_POSTGRES_SSL_MODE=disable

# OpenTelemetry
OTEL_ENABLED=false
OTEL_PROTOCOL=grpc
OTEL_ENDPOINT=localhost:4317

# App
APP_NAME=sheka
APP_PORT=3001
APP_ENV=development
MIN_CONFIDENCE=medium
BASE_URL=http://localhost:3001
CORS_ENABLED=true
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_MAX_AGE_SECONDS=300
LOG_LEVEL=info
